# Variables de entorno para desarrollo local
# Copiar a .env.local y ajustar según sea necesario

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# CORS - URL del frontend
CORS_ORIGIN=http://localhost:5173

# Base de datos (Supabase - futuro)
DATABASE_URL=

# Autenticación (Supabase - futuro)
SUPABASE_URL=
SUPABASE_ANON_KEY=
